generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String               @id @default(uuid())
  email                  String               @unique
  name                   String
  passwordHash           String?
  role                   String               @default("USER")
  status                 String               @default("ACTIVE")
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  isVerified             Boolean              @default(false)
  rewardPoints           Int                  @default(0)
  deletedAt              DateTime?
  failedLoginAttempts    Int                  @default(0)
  lockedUntil            DateTime?
  requiresPasswordChange Boolean              @default(false)
  resetPasswordToken     String?              @unique
  resetPasswordExpires   DateTime?
  googleId               String?              @unique
  facebookId             String?              @unique
  twoFactorCode          String?
  twoFactorExpires       DateTime?
  defaultAddress         String?
  addresses              Address[]
  cart                   Cart?
  orders                 Order[]
  questions              Question[]
  reviews                Review[]
  wishlists              Wishlist[]
  adminLogs              AdminLog[]
  webAuthnCredentials    WebAuthnCredential[]
  returnRequests         ReturnRequest[]
  warrantyClaims         WarrantyClaim[]
  priceDropAlerts        PriceDropAlert[]
  auditLogs              AuditLog[]
  securityAlerts         SecurityAlert[]
}

model Address {
  id              String   @id @default(uuid())
  userId          String
  phoneNumber     String
  city            String
  area            String
  detailedAddress String
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  parentId    String?
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
}

model Product {
  id              String           @id @default(uuid())
  name            String
  slug            String           @unique
  description     String
  brand           String
  price           Float
  compareAtPrice  Float?
  stock           Int              @default(0)
  categoryId      String
  imageUrls       Json
  specs           Json
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  variants        Json?
  warranty        String           @default("1 Year")
  threeDModelUrl  String?
  isActive        Boolean          @default(true)
  condition       String           @default("NEW")
  cartItems       CartItem[]
  flashSale       FlashSale?
  orderItems      OrderItem[]
  category        Category         @relation(fields: [categoryId], references: [id])
  questions       Question[]
  reviews         Review[]
  wishlistedBy    Wishlist[]
  warrantyClaims  WarrantyClaim[]
  priceDropAlerts PriceDropAlert[]
}

model Cart {
  id                 String     @id @default(uuid())
  userId             String?    @unique
  sessionId          String?    @unique
  guestEmail         String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  abandonedEmailSent Boolean    @default(false)
  user               User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items              CartItem[]
}

model CartItem {
  id              String   @id @default(uuid())
  cartId          String
  productId       String
  quantity        Int      @default(1)
  priceAtAddition Float?
  variant         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  cart            Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
}

model Order {
  id                  String               @id @default(uuid())
  userId              String?
  sessionId           String?
  totalAmount         Float
  subtotal            Float                @default(0)
  shippingFee         Float                @default(0)
  discount            Float                @default(0)
  shippingAddress     Json
  paymentStatus       String               @default("PENDING")
  orderStatus         String               @default("PENDING")
  paymentMethod       String
  mpesaReceiptNumber  String?
  trackingNumber      String?
  paymentAttempts     Int                  @default(0)
  cancellationReason  String?
  promoCodeId         String?
  expectedDeliveryDate DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User?                @relation(fields: [userId], references: [id])
  items               OrderItem[]
  promoCode           PromoCode?           @relation(fields: [promoCodeId], references: [id])
  paymentTransactions PaymentTransaction[]
  trackingEvents      TrackingEvent[]
  returnRequests      ReturnRequest[]
  warrantyClaims      WarrantyClaim[]
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  price     Float
  quantity  Int
  variant   String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Review {
  id               String   @id @default(uuid())
  userId           String
  productId        String
  rating           Int
  serviceRating    Int      @default(5)
  comment          String
  verifiedPurchase Boolean  @default(false)
  imageUrls        Json?
  createdAt        DateTime @default(now())
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PromoCode {
  id                 String   @id @default(uuid())
  code               String   @unique
  discountType       String
  discountValue      Float
  maxUses            Int      @default(100)
  usedCount          Int      @default(0)
  expiryDate         DateTime
  active             Boolean  @default(true)
  isForAbandonedCart Boolean  @default(false)
  createdAt          DateTime @default(now())
  orders             Order[]
}

model FlashSale {
  id        String   @id @default(uuid())
  productId String   @unique
  salePrice Float
  startTime DateTime
  endTime   DateTime
  active    Boolean  @default(true)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String?
  sessionId String?
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@unique([sessionId, productId])
}

model Question {
  id        String   @id @default(uuid())
  productId String
  userId    String?
  name      String
  content   String
  answer    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ShippingZone {
  id            String   @id @default(uuid())
  regionName    String   @unique
  fee           Float
  estimatedDays String
  counties      Json     @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model WebAuthnCredential {
  id           String   @id @default(uuid())
  userId       String
  credentialId String   @unique
  publicKey    String
  signCount    Int      @default(0)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WebAuthnChallenge {
  id        String   @id @default(uuid())
  challenge String   @unique
  userId    String?
  sessionId String?
  createdAt DateTime @default(now())
}

model PaymentTransaction {
  id                String   @id @default(uuid())
  orderId           String
  amount            Float
  status            String   @default("PENDING") // PENDING, SUCCESS, FAILED
  provider          String // MPESA, CARD, etc.
  providerRef       String? // mpesa receipt number
  checkoutRequestId String? // mpesa checkout request id
  errorMessage      String?
  rawPayload        Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ReturnRequest {
  id          String   @id @default(uuid())
  orderId     String
  userId      String
  reason      String
  description String
  imageUrls   Json?
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED, REFUNDED
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  order       Order    @relation(fields: [orderId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model WarrantyClaim {
  id          String   @id @default(uuid())
  orderId     String
  productId   String
  userId      String
  issueType   String
  description String
  imageUrls   Json?
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, RESOLVED, REJECTED
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  order       Order    @relation(fields: [orderId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model TrackingEvent {
  id          String   @id @default(uuid())
  orderId     String
  status      String // PLACED, CONFIRMED, PACKED, DISPATCHED, OUT_FOR_DELIVERY, DELIVERED
  location    String?
  description String
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model PriceDropAlert {
  id          String   @id @default(uuid())
  userId      String
  productId   String
  targetPrice Float?
  isNotified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  // nullable for guests
  sessionId String?  // for guests
  action    String
  details   String
  ipAddress String?
  userAgent String?
  severity  String   @default("INFO") // INFO, WARNING, CRITICAL
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SecurityAlert {
  id          String   @id @default(uuid())
  type        String   // e.g. "MULTIPLE_FAILED_LOGINS", "SUSPICIOUS_CART_ACTIVITY"
  description String
  severity    String   @default("HIGH") // HIGH, CRITICAL
  ipAddress   String?
  userId      String?
  isResolved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VisitorSession {
  id        String   @id @default(uuid())
  visitorId String   @unique 
  ipAddress String?
  userAgent String?
  status    String   @default("ONLINE") 
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id               String         @id @default(uuid())
  visitorSessionId String
  sender           String         
  content          String
  read             Boolean        @default(false)
  createdAt        DateTime       @default(now())
  visitorSession   VisitorSession @relation(fields: [visitorSessionId], references: [id], onDelete: Cascade)
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model SiteSettings {
  id            String   @id @default("global") // We only want one row
  storeLocation String   @default("Not set")
  updatedAt     DateTime @updatedAt
}
